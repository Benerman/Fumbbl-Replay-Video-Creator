# Copy to `deploy/.env` (gitignored) and fill in. Both the bot and the
# worker read this file via python-dotenv (and docker compose's env_file).

# --- Discord ----------------------------------------------------------------
# Bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=__paste_bot_token_here__
# Application ID (numeric) from the same developer-portal page.
DISCORD_APPLICATION_ID=__paste_application_id_here__

# Comma-separated list of Discord guild (server) IDs where slash
# commands should sync INSTANTLY. If unset, py-cord syncs commands
# globally — which takes up to 1 hour to propagate to all guilds.
# For dev / single-server setups, get your guild ID by enabling
# Developer Mode in Discord (User Settings → Advanced) and then
# right-clicking your server icon → "Copy Server ID".
# Example:  DISCORD_DEV_GUILD_IDS=123456789012345678,987654321098765432
DISCORD_DEV_GUILD_IDS=

# --- Crypto -----------------------------------------------------------------
# Generate ONCE with the stdlib (no project deps required):
#   python3 -c 'import base64, secrets; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())'
# Fallbacks:
#   openssl rand -base64 32 | tr '+/' '-_'
#   # or, after the docker image is built:
#   cd deploy && docker compose run --rm bot \
#     python -c 'from services.common.crypto import generate_master_key; print(generate_master_key())'
# Rotating this key invalidates every stored YouTube refresh token —
# all guilds would need to re-run /highlight-config set-youtube.
FERNET_MASTER_KEY=__paste_fernet_master_key_here__

# --- YouTube ---------------------------------------------------------------
# OAuth client (Installed / Desktop type) downloaded from
# https://console.cloud.google.com/apis/credentials.
YOUTUBE_CLIENT_SECRETS_JSON=/app/data/client_secret.json

# Refresh token for the bot operator's DEFAULT YouTube channel. Created
# once by running:
#   docker compose exec worker python -m services.worker.youtube_upload --bootstrap-default
# After that, the encrypted token is stored in the SQLite db AND a
# legacy JSON file (the env var below points to the JSON for safe
# backups). Optional — uploads can run purely off the SQLite copy.
DEFAULT_YT_REFRESH_TOKEN_JSON=/app/data/youtube_token.json

# Default upload visibility. Server admins can override per-guild via
# /highlight-config in v2.
YOUTUBE_PRIVACY=public
# Gaming = 20. Full list: https://developers.google.com/youtube/v3/docs/videoCategories/list
YOUTUBE_CATEGORY_ID=20

# --- Rate limit -------------------------------------------------------------
# How many /generate-highlight invocations a single server can make
# within a rolling 10-minute window. Per-user in-flight is always 1.
RATE_LIMIT_PER_GUILD_PER_10MIN=3

# --- Storage roots ----------------------------------------------------------
# Inside the docker image these live at /app/...; for local dev they
# default to ./jobs, ./data, ./out relative to the repo root.
# JOBS_ROOT=/app/jobs
# OUT_ROOT=/app/out
# DATA_ROOT=/app/data

# --- OAuth callback (per-guild flow) ----------------------------------------
# Port exposed on the docker host. Make sure it's reachable from the
# admin's browser. If your bot is behind a reverse proxy, set
# OAUTH_CALLBACK_HOST to the publicly resolvable hostname and update
# the Google OAuth client's redirect URIs to match.
# OAUTH_CALLBACK_HOST=127.0.0.1
# OAUTH_CALLBACK_PORT=38080

# --- fumbbl_replay knobs (optional) ----------------------------------------
# Whichever commentary backend you prefer.
# FUMBBL_COMMENTARY_BACKEND=template
# OPENAI_API_KEY=...
# ANTHROPIC_API_KEY=...

# --- Logging ----------------------------------------------------------------
# LOG_LEVEL=INFO
